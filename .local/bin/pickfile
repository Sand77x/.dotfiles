#!/bin/bash
# Pick a file and choose an action: open or copy path

# Expand ~ if passed
START_DIR=$(realpath "$1")
MAXDEPTH=8

# List directories first, then files
FILE=$(fdfind -i -H -d $MAXDEPTH . "$START_DIR" | sed "s|^$START_DIR/||" | rofi -dmenu -matching prefix -i -p "Select (depth=$MAXDEPTH)" -theme ~/.config/rofi/theme.rasi)

# Exit if nothing selected
echo $FILE
[[ -z "$FILE" ]] && exit

# Prepend the starting directory to get full path
FILE="$START_DIR/$FILE"
# Step 3: choose action
ACTION=$(echo -e "Open file\nCopy path\nTerminal here\nExplorer here\nNvim here" | rofi -matching prefix -dmenu -i -p "Action for $FILE" -theme ~/.config/rofi/theme.rasi)

case "$ACTION" in
    "Open file")
        xdg-open "$FILE"
        ;;
    "Copy path")
        echo "$FILE" | xclip -selection clipboard
        notify-send "Copied file path" "$FILE"
        ;;
    "Terminal here")
        if [[ -d "$FILE" ]]; then
            # It's a directory → open there
            DIR="$FILE"
        else
            # It's a file → open in its parent folder
            DIR="$(dirname "$FILE")"
        fi
        alacritty --working-directory "$DIR"
        ;;
    "Explorer here")
        if [[ -d "$FILE" ]]; then
            # It's a directory → open there
            DIR="$FILE"
        else
            # It's a file → open in its parent folder
            DIR="$(dirname "$FILE")"
        fi
        xdg-open "$DIR"
        ;;
    "Nvim here")
        alacritty -e bash -c nvim "$FILE"
        ;;
    *)
        # Cancelled
        exit
        ;;
esac

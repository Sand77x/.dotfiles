#!/bin/bash

ALARM_SOUND="$HOME/.local/share/links/alarm_sound"
ALARM_ICON="$HOME/.local/share/links/alarm_img"

if [ $# -lt 2 ]; then
    echo "USAGE: alarm [time] [msg]"
    exit 1
fi

TIME="$1"
shift
MSG="$*"

echo "ffplay -v 0 -nodisp -autoexit \"$ALARM_SOUND\" & dunstify -i $ALARM_ICON -u critical \"ALARM\" \"$MSG\"" | at "$TIME" >/dev/null 2>&1

if [ $? -eq 0 ]; then
    echo "Setting alarm \"$MSG\" at $TIME"
    dunstify "ALARM" "Setting alarm \"$MSG\" at $TIME"
else
    echo "Failed to set alarm."
    dunstify "ALARM" "Failed to set alarm."
fi


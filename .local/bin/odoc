#!/bin/bash

odoc() {
    local docdir="$HOME/odoc"
    local help="
odoc <mode> [file] [args]
l   List docs
e   Edit doc [.scratch if none]
d   Delete doc
    "
    local mode="$1"
    local arg="$2"
    local editor
    editor=$(command -v nvim 2>/dev/null || echo nano)

    # Ensure docs directory exists
    mkdir -p "$docdir"

    # Help / usage check
    if [ -z "$mode" ]; then
        echo "$help"
        return
    fi

    local slashes="${arg//[^\/]}"
    local n_slashes="${#slashes}"

    local file="$docdir/$arg.md"

    case "${mode,,}" in
        "l")
            tree "$docdir"
            ;;

        "e")
            if [ -z "$arg" ]; then
                file="$docdir/.scratch.md"
                [ ! -e "$file" ] && echo "# scratch" > "$file"
            fi

            innerdocdir="$(dirname "$file")"
            [ $n_slashes -gt 0 ] && mkdir -p "$innerdocdir"

            "$editor" "$file"

            if [ ! -e "$file" ] && [ $n_slashes -gt 0 ]; then
                rmdir "$innerdocdir" 2>/dev/null
            fi
            ;;

        "d")
            if [ ! -e "$file" ]; then
                echo "Doc doesn't exist."
                return
            fi
            rm -v "$file"
            ;;

        *)
            echo "Invalid mode."
            ;;
    esac
}

odoc "$@"
